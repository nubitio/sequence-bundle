{
    "name": "nubitio/sequence-bundle",
    "description": "Opt-in atomic field numbering for Nubit Symfony apps via the Sequence attribute and a shared counter table.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "sequence",
        "numbering",
        "nubit"
    ],
    "homepage": "https://github.com/nubitio/nubit-symfony/tree/main/packages/sequence-bundle",
    "support": {
        "issues": "https://github.com/nubitio/nubit-symfony/issues",
        "source": "https://github.com/nubitio/nubit-symfony"
    },
    "require": {
        "php": ">=8.2",
        "api-platform/core": "^4.1",
        "doctrine/orm": "^3.0",
        "nubitio/api-platform": "0.*",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/property-access": "^7.4 || ^8.0",
        "symfony/serializer": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nubit\\SequenceBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nubit\\SequenceBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
